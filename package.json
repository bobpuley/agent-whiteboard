{
  "name": "agent-whiteboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"server,client,browser\" \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:open\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:open": "wait-on http://localhost:5173 && node -e \"import('open').then(m => m.default('http://localhost:5173'))\"",
    "build": "tsc -p tsconfig.json && vite build --config client/vite.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "hono": "^4.7.11",
    "mermaid": "^11.15.0",
    "open": "^10.1.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^2.4.6",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.17.57",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "svelte": "^4.2.19",
    "tsx": "^3.14.0",
    "typescript": "^5.8.3",
    "vite": "^4.5.10",
    "vitest": "^0.34.6",
    "wait-on": "^8.0.3"
  }
}
