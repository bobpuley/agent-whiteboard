{
  "name": "agent-whiteboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"server,client,browser\" \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:open\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:open": "wait-on http://localhost:5173 && node -e \"import('open').then(m => m.default('http://localhost:5173'))\"",
    "dev:test": "concurrently --kill-others-on-fail --names \"server,client\" \"tsx server/index.ts\" \"npm run dev:client\"",
    "typecheck": "svelte-check --tsconfig client/tsconfig.json",
    "build": "tsc -p tsconfig.json && npm run typecheck && vite build --config client/vite.config.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/dompurify": "^3.2.0",
    "bootstrap": "^5.3.8",
    "dompurify": "^3.4.7",
    "happy-dom": "^20.10.6",
    "hono": "^4.7.11",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "open": "^10.1.2",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^2.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^4.2.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.17.57",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "svelte": "^4.2.19",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "tsx": "^3.14.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^4.5.10",
    "vitest": "^0.34.6",
    "wait-on": "^8.0.3"
  }
}
